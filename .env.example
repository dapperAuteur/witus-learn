# ── Core ───────────────────────────────────────────────────────────────────
# Neon Postgres. Pooled URL for the app runtime; unpooled (direct) for migrations.
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/witus_learn?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:pass@ep-xxx.region.aws.neon.tech/witus_learn?sslmode=require

# Default/marketing host (no trailing slash). Per-tenant hosts live in tenant_domains.
NEXT_PUBLIC_APP_URL=http://localhost:3040

# ── Better Auth (magic-link) ─────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-a-random-string-at-least-32-characters-long
BETTER_AUTH_URL=http://bvc.localhost:3040

# Seed account granted is_platform_owner by scripts/seed-tenants.ts
PLATFORM_OWNER_EMAIL=you@example.com

# Local dev: override the resolved tenant host when not using *.localhost subdomains.
# DEV_TENANT_HOST=bvc.localhost

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Per-tenant from/reply-to live in the tenants table; this is the platform default.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Learn.WitUS <no-reply@witus.online>

# ── Stripe (own account) — Phase 5 ───────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI (Gemini) — Phase 6 ────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=

# ── Media (Cloudinary) — Phases 4/8 ──────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Ecosystem (optional, per-tenant flag) ────────────────────────────────────
# FLASHLEARN_ECO_API_KEY=
# INBOX_INGEST_URL=
# INBOX_SOURCE_SLUG=
# INBOX_INGEST_SECRET=
