{
  "name": "witus-learn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3040",
    "build": "next build --webpack",
    "start": "next start -p 3040",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local scripts/migrate.ts",
    "db:migrate:prod": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:tenants": "tsx --env-file=.env.local scripts/seed-tenants.ts",
    "seed:bvc": "tsx --env-file=.env.local scripts/seed-bvc.ts",
    "seed:map": "tsx --env-file=.env.local scripts/seed-map.ts",
    "seed:languages": "tsx --env-file=.env.local scripts/seed-languages.ts",
    "seed:courses": "tsx --env-file=.env.local scripts/seed-courses.ts",
    "seed:faa": "tsx --env-file=.env.local scripts/seed-faa.ts",
    "seed:bvc:real": "tsx --env-file=.env.local scripts/seed-bvc-real.ts",
    "gen:health": "tsx scripts/gen-health-data.ts",
    "seed:health": "tsx --env-file=.env.local scripts/seed-health.ts",
    "seed:speedway": "tsx --env-file=.env.local scripts/seed-speedway.ts",
    "seed:owner": "tsx --env-file=.env.local scripts/seed-owner.ts",
    "srt:transcript": "tsx --env-file=.env.local scripts/srt-to-transcript.ts",
    "course:script": "tsx --env-file=.env.local scripts/course-to-script.ts",
