    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.6.2",
    "csv-parse": "^6.2.1",
    "d3-geo": "^3.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "form-data": "^4.0.5",
    "mailgun.js": "^12.7.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
